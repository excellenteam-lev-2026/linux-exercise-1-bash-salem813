#!/usr/bin/env bash

NO_EMAIL=false
FILE=""
LIST=false
while [[ $# -gt 0 ]]; do
  case $1 in
    -l|--list )
      LIST=true
      shift
      ;;
    --no-email )
      NO_EMAIL=true
      shift
      ;;
    * )
      break
  esac
done
# Fixed a syntax issue in line 21 related to the LIST condition.
if [ "$LIST" != "true" ]; then
  FILE=$1
  if [ -z "$FILE" ]; then
    FILE=$(find . -mindepth 1 -maxdepth 1 \( -iname '*authors*' -o -iname '*contributors*' \) | head -n1)
    if [ -z "$FILE" ]; then
      FILE='AUTHORS'
    fi
  fi
fi

#
# list authors sorted by number of commits (descending).
#

authors() {
  if $NO_EMAIL; then
    # email will be used to uniq authors.
    git shortlog HEAD -sne | awk '{$1=""; sub(" ", ""); print}' | awk -F'<' '!x[$1]++' | awk -F'<' '!x[$2]++' \
      | awk -F'<' '{gsub(/ +$/, "", $1); print $1}'
  else
    git shortlog HEAD -sne | awk '{$1=""; sub(" ", ""); print}' | awk -F'<' '!x[$1]++' | awk -F'<' '!x[$2]++'
  fi
}

#
# authors.
#
# Corrected the final output logic so that the authors list is printed with --list and written to the AUTHORS file otherwise.
if $LIST; then
  authors
else
  authors > "$FILE"
fi
